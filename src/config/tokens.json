{
  "$comment": "Single source of truth for the design system. Mirror these into CSS vars in src/index.css and into tailwind.config.js. Do NOT consume directly from JS hot paths — use the CSS var or Tailwind class.",
  "color": {
    "bg": {
      "primary": "#050816",
      "tertiary": "#151030",
      "black100": "#100d25",
      "black200": "#090325"
    },
    "ink": {
      "primary": "#ffffff",
      "secondary": "#aaa6c3",
      "muted": "#dfd9ff",
      "white100": "#f3f3f3"
    },
    "accent": {
      "primary": "#915eff",
      "primaryRgb": "145, 94, 255",
      "secondary": "#00cea8",
      "secondaryRgb": "0, 206, 168",
      "tertiary": "#bf61ff",
      "info": "#61dafb",
      "warn": "#f8c555",
      "danger": "#ff6b6b"
    },
    "themes": {
      "space": { "accent": "#915eff", "bg": "#050816" },
      "cyber": { "accent": "#00f0ff", "bg": "#0a0014" },
      "matrix": { "accent": "#00ff41", "bg": "#000a00" }
    }
  },
  "type": {
    "family": {
      "sans": "Saira",
      "heading": "Chakra Petch",
      "mono": "Martian Mono"
    },
    "$comment": "Sizes are fluid clamp(min, fluid, max). Min targets ~380px viewport, max targets ~1440px; ultrawide scales beyond via maxWidth caps, not type.",
    "scale": {
      "displayXl": "clamp(2.25rem, 1rem + 5.5vw, 4.75rem)",
      "display": "clamp(2rem, 0.75rem + 4.5vw, 3.75rem)",
      "displaySm": "clamp(1.75rem, 0.5rem + 4vw, 3rem)",
      "headingXl": "clamp(1.5rem, 0.5rem + 3vw, 2.5rem)",
      "heading": "clamp(1.25rem, 0.5rem + 2vw, 1.875rem)",
      "headingSm": "clamp(1.125rem, 0.5rem + 1.5vw, 1.5rem)",
      "subheading": "clamp(1.0625rem, 0.5rem + 1vw, 1.25rem)",
      "bodyLg": "clamp(1rem, 0.5rem + 0.5vw, 1.125rem)",
      "body": "1rem",
      "bodySm": "0.875rem",
      "caption": "0.75rem",
      "micro": "0.6875rem"
    }
  },
  "space": {
    "fluid": {
      "sm": "clamp(1rem, 2vw, 1.5rem)",
      "md": "clamp(2rem, 4vw, 3rem)",
      "lg": "clamp(3rem, 6vw, 5rem)",
      "xl": "clamp(4rem, 8vw, 6rem)",
      "2xl": "clamp(5rem, 10vw, 8rem)"
    }
  },
  "screen": {
    "xs": "390px",
    "sm": "640px",
    "md": "768px",
    "ml": "896px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px",
    "3xl": "1920px",
    "4xl": "2560px",
    "5xl": "3440px"
  },
  "container": {
    "3xl": "1920px",
    "4xl": "2400px",
    "5xl": "3000px"
  },
  "motion": {
    "duration": {
      "fast": "150ms",
      "base": "300ms",
      "long": "500ms",
      "slow": "1000ms"
    },
    "easing": {
      "out": "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },
  "z": {
    "$comment": "Semantic z-index scale — never use arbitrary integers in code.",
    "background": 0,
    "particles": 1,
    "content": 10,
    "skillHover": 20,
    "tooltip": 30,
    "navbar": 40,
    "mobileMenu": 50,
    "commandTerminal": 60,
    "keyboardHints": 65,
    "preloader": 80,
    "modal": 90,
    "toast": 90,
    "spotlightSearch": 95,
    "customCursor": 98
  }
}
